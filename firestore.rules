rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Restrict access to existing documents only (no create or delete)
    match /{collection}/{document} {
      allow read: if true;
      
      // Only allow updates that:
      // 1. Only modify the 'likes' and 'lastUpdate' fields
      // 2. Result in an incremented 'likes' count
      // 3. Set 'lastUpdate' to current server time
      // 4. Rate limited: max 2 updates per second (500ms)
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'lastUpdate'])
        && request.resource.data.likes > resource.data.likes
        && request.resource.data.lastUpdate == request.time
        && (
          !('lastUpdate' in resource.data) 
          || request.time >= resource.data.lastUpdate + duration.value(500, 'ms')
        )
      );
    }
  }
}
