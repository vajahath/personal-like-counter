{
  "name": "@vajahath/personal-like-counter",
  "type": "module",
  "version": "1.0.2",
  "description": "A personal utility package for managing like counts with Firebase Firestore.",
  "author": "Vajahath Ahmed",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vajahath/personal-like-counter.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "demo": "bun run build && mkdir -p demo/dist && cp -r dist/* demo/dist/ && bun x serve demo"
  },
  "dependencies": {},
  "peerDependencies": {
    "debounce": "^3.0.0",
    "firebase": "^12.10.0",
    "p-retry": "^7.1.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "bumpp": "^10.3.2",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "packageManager": "bun@1.3.0"
}
